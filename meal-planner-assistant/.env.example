# =============================================================================
# ADK Local Authentication
# =============================================================================
# Two modes — pick ONE:
#
#   Mode A) Gemini API (AI Studio key) — simpler, no GCP project needed
#     - Set GOOGLE_API_KEY below
#     - Get key from: https://aistudio.google.com/apikey
#
#   Mode B) Vertex AI (your GCP project) — needed for GCP-only features
#     - Uncomment GOOGLE_CLOUD_PROJECT + GOOGLE_CLOUD_LOCATION
#     - Run:  gcloud auth application-default login
#     - GOOGLE_API_KEY can be empty/removed in this mode
#
GOOGLE_API_KEY="your_gemini_api_key"
AI_ENABLED=true

# Uncomment these for Vertex AI mode (Mode B):
# GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# GOOGLE_CLOUD_LOCATION="us-east1"

# =============================================================================
# OpenRouter — lightweight fallback model (optional)
# =============================================================================
# HERMES_API_KEY="sk-or-v1-..."
# HERMES_API_BASE="https://openrouter.ai/api/v1"
# HERMES_MODEL="openrouter/nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free"
# OPENROUTER_API_KEY="sk-or-v1-..."

# =============================================================================
# Database — PostgreSQL (optional, falls back to in-memory if unavailable)
# =============================================================================
# Uncomment DATABASE_URL to use a single connection string (overrides individual fields):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/meal_planner
#
# Or set individual fields:
DB_HOST=127.0.0.1
DB_NAME=meal_planner
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =============================================================================
# MCP Server Timeouts (seconds)
# =============================================================================
PROFILE_MCP_TIMEOUT=30
INVENTORY_MCP_TIMEOUT=30

# =============================================================================
# FatSecret Platform API (OAuth 2.0) — requires IP whitelist
# =============================================================================
# Get credentials at: https://platform.fatsecret.com
# Then register your server IP in: My Applications → Edit → Allowed IP Addresses
FATSECRET_CLIENT_ID="your_fatsecret_client_id"
FATSECRET_CLIENT_SECRET="your_fatsecret_client_secret"
